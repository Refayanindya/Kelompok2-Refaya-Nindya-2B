        String nim = input.nextLine();

        for (int i = 0; i < jumlahData; i++) {
            if (data[i] != null && data[i].nim.equals(nim) && data[i].aktif) {
                data[i].nama = inputString("Nama baru: ");
                data[i].kategori = inputString("Kategori baru: ");
                data[i].nilaiTugas = inputNilai("Nilai Tugas baru: ");
                data[i].nilaiUTS = inputNilai("Nilai UTS baru: ");
                data[i].nilaiUAS = inputNilai("Nilai UAS baru: ");
                //updet nilai akhir dan grade
                data[i].hitungNilaiAkhir();
                data[i].tentukanGrade();

                simpanData();
                System.out.println("Data berhasil diupdate!");
                return;
            }
        }

        System.out.println("Data tidak ditemukan.");
    }

    //Hapus data secara soft delete
    static void hapusData() {
    System.out.print("Masukkan NIM yang ingin dihapus: ");
    String nim = input.nextLine();

    for (int i = 0; i < jumlahData; i++) {
        if (data[i] != null && data[i].nim.equals(nim) && data[i].aktif) {
            data[i].aktif = false;
            simpanData();
            System.out.println("Data berhasil dihapus .");
            return;
        }
    }

    System.out.println("Data tidak ditemukan atau sudah dihapus.");
}

    //Mencari berdasarkan nama
    static void cariNama() {
        System.out.print("Masukkan nama: ");
        String nama = input.nextLine();
        boolean ditemukan = false;

        headerTabel();

        for (int i = 0; i < jumlahData; i++) {
            if (data[i] != null && data[i].aktif && data[i].nama.equalsIgnoreCase(nama)) {
                data[i].tampilkanData();
                ditemukan = true;
            }
        }

        System.out.println("==============================================================================================================");

        if (!ditemukan) {
            System.out.println("Data tidak ditemukan.");
        }
    }

    //menampiljjan data yang terhapus
    static void tampilkanDataTerhapus() {
    boolean ada = false;

    headerTabel();

    for (int i = 0; i < jumlahData; i++) {
        if (data[i] != null && !data[i].aktif) { 
            data[i].tampilkanData();
            ada = true;
        }
    }

    System.out.println("==============================================================================================================");

    if (!ada) {
        System.out.println("Tidak ada data yang dihapus.");
    }
}

    //Mengembalikan data yang diapus
    static void restoreData() {
    System.out.print("Masukkan NIM yang ingin direstore: ");
    String nim = input.nextLine();

    for (int i = 0; i < jumlahData; i++) {
        if (data[i] != null && data[i].nim.equals(nim) && !data[i].aktif) {
            data[i].aktif = true;
            simpanData();
            System.out.println("Data berhasil direstore!");
            return;
        }
    }

    System.out.println("Data tidak ditemukan atau sudah aktif.");
}

    //Mengurutkan data sdengan buble sort
    static void bubbleSortNIM() {
        for (int i = 0; i < jumlahData - 1; i++) {
            for (int j = 0; j < jumlahData - i - 1; j++) {
                if (data[j].nim.compareTo(data[j + 1].nim) > 0) {
                    Mahasiswa temp = data[j];
                    data[j] = data[j + 1];
                    data[j + 1] = temp;
                }
            }
        }

        System.out.println("Data berhasil diurutkan berdasarkan NIM.");
    }

    //Binary serch berdasarkan nim
    static void binarySearchNIM() {
        bubbleSortNIM();

        System.out.print("Masukkan NIM yang dicari: ");
        String nim = input.nextLine();

        int kiri = 0, kanan = jumlahData - 1;
        boolean ditemukan = false;

        while (kiri <= kanan) {
            int tengah = (kiri + kanan) / 2;
            int hasil = data[tengah].nim.compareTo(nim);

            if (hasil == 0 && data[tengah].aktif) {
                headerTabel();
                data[tengah].tampilkanData();
                System.out.println("==============================================================================================================");
                ditemukan = true;
                break;
            } else if (hasil < 0) {
                kiri = tengah + 1;
            } else {
                kanan = tengah - 1;
            }
        }

        if (!ditemukan) {
            System.out.println("Data tidak ditemukan.");
        }
    }

    //Mengurutkan data berdasarkan nama
    static void selectionSortNama() {
        for (int i = 0; i < jumlahData - 1; i++) {
            int min = i;

            for (int j = i + 1; j < jumlahData; j++) {
                if (data[j].nama.compareToIgnoreCase(data[min].nama) < 0) {
                    min = j;
                }
            }

            Mahasiswa temp = data[i];
            data[i] = data[min];
            data[min] = temp;
        }

        System.out.println("Data berhasil diurutkan berdasarkan Nama.");
    }

