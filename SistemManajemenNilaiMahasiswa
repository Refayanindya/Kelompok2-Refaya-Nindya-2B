    // Validasi input nilai
static double inputNilai(String pesan) {
    double nilai;

    while (true) {
        try {
            System.out.print(pesan);
            nilai = input.nextDouble();
            input.nextLine();

            if (nilai >= 0 && nilai <= 100) {
                return nilai;
            } else {
                System.out.println("Nilai harus antara 0 - 100!");
            }

        } catch (Exception e) {
            System.out.println("Input harus angka!");
            input.nextLine();
        }
    }
}

// Validasi input teks
static String inputString(String pesan) {
    String teks;

    while (true) {
        System.out.print(pesan);
        teks = input.nextLine();

        if (!teks.trim().isEmpty()) {
            return teks;
        } else {
            System.out.println("Input tidak boleh kosong!");
        }
    }
}

    //Menambahkan data baru
    static void tambahData() {

    if (jumlahData >= data.length) {
        System.out.println("Data sudah penuh!");
        return;
    }

    String nim;

    while (true) {
        nim = inputString("NIM: ");

        if (!cekNIM(nim)) {
            break;
        } else {
            System.out.println("NIM sudah digunakan!");
        }
    }

    String nama = inputString("Nama: ");
    String kategori = inputString("Kategori/Jurusan: ");

    double tugas = inputNilai("Nilai Tugas: ");
    double uts = inputNilai("Nilai UTS: ");
    double uas = inputNilai("Nilai UAS: ");

    // CEK APAKAH NIM PERNAH DIHAPUS
    for (int i = 0; i < jumlahData; i++) {

        if (data[i] != null &&
            data[i].nim.equals(nim) &&
            !data[i].aktif) {

            System.out.println("NIM pernah dihapus, data akan digunakan kembali.");

            data[i].nama = nama;
            data[i].kategori = kategori;
            data[i].nilaiTugas = tugas;
            data[i].nilaiUTS = uts;
            data[i].nilaiUAS = uas;
            data[i].aktif = true;

            data[i].hitungNilaiAkhir();
            data[i].tentukanGrade();

            simpanData();

            System.out.println("Data berhasil direstore!");
            return;
        }
    }

    // TAMBAH DATA BARU
    data[jumlahData++] = new Mahasiswa(
            nim,
            nama,
            kategori,
            tugas,
            uts,
            uas
    );

    simpanData();

    System.out.println("Data berhasil ditambahkan!");
}

//load data
static void loadData() {

    try {

        java.io.File file =
                new java.io.File("data_mahasiswa.txt");

        Scanner baca = new Scanner(file);

        while (baca.hasNextLine()) {

            String baris = baca.nextLine();

            String[] hasil = baris.split(";");

            Mahasiswa m = new Mahasiswa(
                    hasil[0],
                    hasil[1],
                    hasil[2],
                    Double.parseDouble(hasil[3]),
                    Double.parseDouble(hasil[4]),
                    Double.parseDouble(hasil[5])
            );

            m.aktif = Boolean.parseBoolean(hasil[6]);

            data[jumlahData++] = m;
        }

        baca.close();

        System.out.println("Data berhasil diload!");

    } catch (Exception e) {

        System.out.println("File belum ada, memakai data awal.");

        isiDataAwal();

        simpanData();
    }
}

// simpan data 
static void simpanData() {
    try {
        java.io.PrintWriter simpan =
                new java.io.PrintWriter("data_mahasiswa.txt");

        for (int i = 0; i < jumlahData; i++) {

            if (data[i] != null) {

                simpan.println(
                        data[i].nim + ";" +
                        data[i].nama + ";" +
                        data[i].kategori + ";" +
                        data[i].nilaiTugas + ";" +
                        data[i].nilaiUTS + ";" +
                        data[i].nilaiUAS + ";" +
                        data[i].aktif
                );
            }
        }

        simpan.close();

    } catch (Exception e) {
        System.out.println("Gagal menyimpan data!");
    }
}

// Mengecek NIM sudah ada atau belum
static boolean cekNIM(String nim) {
    for (int i = 0; i < jumlahData; i++) {

        // hanya cek data yang aktif
        if (data[i] != null &&
            data[i].aktif &&
            data[i].nim.equals(nim)) {

            return true;
        }
    }
    return false;
}

